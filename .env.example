PORT=4000
JWT_SECRET=cambia_esto_en_produccion_minimo_32_caracteres
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173
# DB_LOGGING=true

# --- Supabase = base PostgreSQL para este backend (login/tareas siguen siendo tu API Express + JWT)
# 1) Panel → Project Settings → Database → Connection string → URI → Direct (puerto 5432).
# 2) Sustituye [YOUR-PASSWORD] por la contraseña de la base.
# 3) En Supabase → SQL Editor, ejecuta supabase/schema.sql O deja que sequelize.sync() cree tablas al arrancar.
# Puedes usar DATABASE_URL o SUPABASE_DB_URL (cualquiera de las dos).
# Mismo proyecto que el front: Settings → Database → URI (direct, :5432).
DATABASE_URL=
# SUPABASE_DB_URL=

# Solo referencia (opcional); el backend no la usa — el front usa VITE_SUPABASE_URL.
# SUPABASE_PROJECT_URL=https://TU_REF.supabase.co

# SSL: automático si la URL es de supabase.co / supabase.com. Postgres local: DB_SSL=false
# DB_SSL=false

# --- MySQL local / Docker (solo si DATABASE_URL y SUPABASE_DB_URL están vacíos)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=optimatask
DB_USER=root
DB_PASSWORD=

# --- Postgres sin URI (opcional)
# DB_DIALECT=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=
